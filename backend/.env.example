# AnchorPoint Backend Configuration

# Environment
NODE_ENV=development
PORT=3002

# Database
DATABASE_URL=file:./prisma/dev.db

# JWT
JWT_SECRET=your-secret-key-min-8-chars

# URLs
INTERACTIVE_URL=http://localhost:3000
BASE_URL=http://localhost:3002

# Webhook Configuration
WEBHOOK_URL=https://your-webhook-endpoint.com
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_MS=500

# Stellar Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_BASE_FEE=100

# Key Management (Encrypted Storage)
# Backend: aws-kms or vault
KEY_MANAGEMENT_BACKEND=aws-kms

# AWS KMS Configuration (if using aws-kms backend)
# AWS KMS key ARN for encrypting provider keys
AWS_KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012
AWS_REGION=us-east-1
# AWS credentials (optional if using IAM role)
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Vault Configuration (if using vault backend)
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_TOKEN=s.xxxxxxxxxxxxxxxx
# VAULT_TRANSIT_PATH=transit/keys/stellar-keys

# Signing Key (Public key for SEP-1 info endpoint)
# This is the public key used for signing, NOT a private key
SIGNING_KEY=GBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Receiving and Distribution Accounts
RECEIVING_ACCOUNT=GBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# DISTRIBUTION_ACCOUNT=GBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# SEP Endpoints
FEDERATION_SERVER=https://your-domain.com/.well-known/stellar.toml
AUTH_SERVER=https://your-domain.com/auth
KYC_SERVER=https://your-domain.com/kyc
WEB_AUTH_ENDPOINT=https://your-domain.com/auth/challenge
TRANSFER_SERVER=https://your-domain.com/sep6
TRANSFER_SERVER_SEP24=https://your-domain.com/sep24
DEPOSIT_SERVER=https://your-domain.com/sep6
WITHDRAWAL_SERVER=https://your-domain.com/sep6

# Documentation
DOCUMENTATION_URL=https://your-domain.com/docs

# Preflight Commit
PREFLIGHT_COMMIT=false

# Logging
LOG_LEVEL=info
# LOG_DIR=./logs
# LOGSTASH_HOST=logstash.example.com
# LOGSTASH_PORT=5000

# Redis (for rate limiting and sequence number management)
REDIS_URL=redis://localhost:6379

# Tracing (OpenTelemetry)
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=anchorpoint-backend
# OTEL_SERVICE_VERSION=1.0.0

# Alert Notifications
# ALERT_WEBHOOK_URL=https://your-webhook.com/alerts
# ALERT_EMAIL_RECIPIENTS=admin@example.com

# Feature Flags
# FEATURE_FLAG_MULTISIG=true
# FEATURE_FLAG_BATCH_PAYMENTS=true

# Note: NEVER commit plaintext private keys to this file.
# Use KEY_MANAGEMENT_BACKEND to encrypt keys at rest.
# For local development, use test keys only.
